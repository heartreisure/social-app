{
  "name": "social-vibe-app",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "test": "vitest",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "smoke:runtime": "vitest run tests/runtime-smoke --dangerouslyIgnoreUnhandledErrors",
    "smoke:runtime:ci": "vitest run tests/runtime-smoke --reporter=json --outputFile=artifacts/quality/runtime-smoke.json --dangerouslyIgnoreUnhandledErrors && node scripts/annotate-quality-artifact.mjs --file artifacts/quality/runtime-smoke.json --gate runtime_smoke --schema 1.0.0",
    "test:permissions": "vitest run tests/integration/supabase-rest.test.ts --reporter=json --outputFile=artifacts/quality/permission-regression.json --dangerouslyIgnoreUnhandledErrors && node scripts/annotate-quality-artifact.mjs --file artifacts/quality/permission-regression.json --gate permission_regression --schema 1.0.0",
    "smoke:routes": "node scripts/smoke-routes.mjs",
    "coverage:check": "node scripts/check-coverage-threshold.mjs",
    "quality:manifest": "node scripts/build-quality-manifest.mjs",
    "quality:schema:check": "node scripts/check-artifact-schema-compatibility.mjs",
    "verify:prod": "node scripts/verify-production-readiness.mjs",
    "dashboard:refresh": "python3 \"$(cat ~/.gse-one)/tools/dashboard.py\"",
    "dashboard:watch": "bash scripts/dashboard-tick.sh"
  },
  "dependencies": {
    "framer-motion": "^11.11.17",
    "next": "^14.2.15",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@testing-library/react": "^16.1.0",
    "@testing-library/user-event": "^14.5.2",
    "@types/node": "^22.10.1",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitest/coverage-v8": "^2.1.8",
    "autoprefixer": "^10.4.20",
    "eslint": "^8.57.1",
    "eslint-config-next": "^14.2.15",
    "jsdom": "^24.1.3",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.16",
    "typescript": "^5.6.3",
    "vitest": "^2.1.8"
  }
}
